local AllCategories = {CombatData, VisualsData}

local function BuildCategoryFromData(data)
    local catObj = Toolbox:Category(data.name)
    
    for _, item in ipairs(data.items) do
        
        -- Handle Main Modules (Toggles)
        if item.type == "toggle" then
            
            local modApi, toggleFunc = catObj:ModuleSettingDropdown(item.label, false, function(isOn)
                -- When module toggled in menu, update shortcut visual
                local reg = _G.ModuleRegistry[item.path]
                if reg then
                    reg.isOn = isOn
                    reg.updateShortcut(isOn)
                end
                print(item.label .. " Toggled: " .. tostring(isOn))
            end)
            
            -- Register module for Shortcuts
            if item.has_shortcut then
                _G.ModuleRegistry[item.path] = {
                    api = modApi,
                    toggleFunc = toggleFunc,
                    isOn = false,
                    updateShortcut = function() end, -- Placeholder
                    label = item.label,
                    icon = item.icon or data.icon or "rbxassetid://0", -- Priority: Item > Category > Default
                    isAction = false
                }
            end
            
            if item.items then
                for _, sub in ipairs(item.items) do
                    if sub.type == "slider" then
                        local min = sub.range and sub.range[1] or 0
                        local max = sub.range and sub.range[2] or 100
                        
                        modApi:Slider(sub.label, min, max, min, 1, function(val)
                            print("Updated [" .. sub.path .. "] to: " .. val)
                        end)
                    
                    elseif sub.type == "toggle" then
                        modApi:Toggle(sub.label, false, function(v)
                             print("Updated [" .. sub.path .. "] to: " .. tostring(v))
                        end)
                    
                    elseif sub.type == "checkbox" then
                        modApi:Checkbox(sub.label, false, function(v)
                             print("Updated [" .. sub.path .. "] to: " .. tostring(v))
                        end)
                        
                    elseif sub.type == "select" then
                         modApi:Select(sub.label, sub.options or {})
                    elseif sub.type == "multiselect" then
                         modApi:MultiSelect(sub.label, sub.options or {})
                    end
                end
            end
            
        -- Handle Action Buttons (One Time Click)
        elseif item.type == "action" then
            catObj:OneTimeButton(item.label, function()
                print("Triggered Action: " .. item.path)
            end)
            -- Register Actions for Shortcuts
            if item.has_shortcut then
                _G.ModuleRegistry[item.path] = {
                    toggleFunc = function() print("Triggered Action via Shortcut: " .. item.path) end,
                    isOn = false,
                    updateShortcut = function() end,
                    label = item.label,
                    icon = item.icon or data.icon or "rbxassetid://0",
                    isAction = true
                }
            end
        
        -- Handle Divider (With optional contents)
        elseif item.type == "divider" then
            local divApi = catObj:Divider(item.label)
             if item.items then
                for _, sub in ipairs(item.items) do
                       if sub.type == "slider" then
                         local min = sub.range and sub.range[1] or 0
                         local max = sub.range and sub.range[2] or 100
                         divApi:Slider(sub.label, min, max, min, 1, function(val) end)
                       end
                end
            end

        -- Handle Player Teleport Divider + Dropdown
        elseif item.type == "player_list" then
            local divApi = catObj:Divider(item.label) -- Creates the Divider Header
            
            -- Setup Player List Variables
            local getPlayers = function()
                local p = {}
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl ~= LocalPlayer then table.insert(p, pl.Name) end
                end
                return p
            end
            
            -- Create Dropdown Inside Divider
            local _, updateDropdown = divApi:Select("Target Player", getPlayers())
            
            -- Auto-Update Logic
            Players.PlayerAdded:Connect(function() updateDropdown(getPlayers()) end)
            Players.PlayerRemoving:Connect(function() updateDropdown(getPlayers()) end)
            
            -- Confirm Button Inside Divider
            local function confirmTP()
                print("Teleporting to selected target...")
            end
            divApi:TextButton("Confirm Teleport", confirmTP)

            -- Register for shortcuts
            if item.has_shortcut then
                _G.ModuleRegistry[item.path] = {
                    toggleFunc = confirmTP,
                    isOn = false,
                    updateShortcut = function() end,
                    label = item.label,
                    icon = item.icon or data.icon or "rbxassetid://0",
                    isAction = true
                }
            end
        end
    end
    
    return catObj
end

