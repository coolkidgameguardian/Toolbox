local function createSlideTween(instance, originalPos, isClosing)
    local targetPos
    if isClosing then
        targetPos = UDim2.fromOffset(-DESIGN_WIDTH - 120, originalPos.Y.Offset)
    else
        targetPos = UDim2.fromOffset(originalPos.X.Offset, originalPos.Y.Offset)
    end

    local duration = getAnimSpeed()
    local info = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    return TweenService:Create(instance, info, {Position = targetPos})
end

MinButton.MouseButton1Click:Connect(function()
    if isMin then return end
    isMin = true
    
    createSlideTween(MainPlate, PosCache.Main, true):Play()
    createSlideTween(LinkPlate, PosCache.Link, true):Play()
    createSlideTween(CatListPlate, PosCache.Cat, true):Play()
    createSlideTween(ModulePlate, PosCache.Mod, true):Play()
    createSlideTween(LogoPlate, PosCache.Logo, true):Play()
    createSlideTween(MinPlate, PosCache.Min, true):Play()

    -- If animations off, hide instantly. Else wait for slide
    local delayTime = getAnimSpeed() > 0 and getAnimSpeed() or 0
    task.delay(delayTime, function() Restore.Visible = true end)
end)

