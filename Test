                    local reg = _G.ModuleRegistry[item.path]
                    
                    local row = Instance.new("Frame", ShortcutsScroll)
                    row.Name = "ShortcutRow"
                    row.Size = UDim2.new(1, 0, 0, 50)
                    row.BackgroundTransparency = 1
                    
                    -- Icon (Left Side) - Matches Module Icon
                    local icon = Instance.new("ImageLabel", row)
                    icon.Size = UDim2.new(0, 30, 0, 30)
                    icon.Position = UDim2.new(0, 10, 0.5, 0)
                    icon.AnchorPoint = Vector2.new(0, 0.5)
                    icon.BackgroundTransparency = 1
                    icon.Image = reg.icon
                    icon.ImageColor3 = WHITE
                    
                    -- Name Label (Left Side, next to Icon)
                    local lbl = Instance.new("TextLabel", row)
                    lbl.Name = "Label"
                    lbl.Text = item.label
                    lbl.Size = UDim2.new(0.5, 0, 1, 0)
                    lbl.Position = UDim2.new(0, 50, 0, 0) -- Adjusted padding
                    lbl.BackgroundTransparency = 1
                    lbl.TextColor3 = WHITE
                    lbl.Font = mainFont
                    lbl.TextSize = 18
                    lbl.TextXAlignment = Enum.TextXAlignment.Left
                    
                    -- Mobile Control (Checkbox in Tab -> Spawns Draggable Circle on Screen)
                    if IsMobile then
                        -- Checkbox Container (Far Right)
                        local chkFrame = createCheckbox("", false, function(isOn)
                            -- This function creates/destroys the draggable circle
                            if isOn then
                                -- CREATE CIRCLE BUTTON
                                local btn = Instance.new("ImageButton", MobileOverlay)
                                btn.Name = "Shortcut_" .. item.path
                                btn.Size = UDim2.new(0, 50, 0, 50)
                                btn.Position = UDim2.new(0.8, 0, 0.5, 0) -- Spawn on right side
                                btn.AnchorPoint = Vector2.new(0.5, 0.5)
                                btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
                                btn.BackgroundTransparency = 0.5
                                btn.Image = "" -- No image on button itself
                                btn.ScaleType = Enum.ScaleType.Fit
                                Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0) -- Perfect Circle
                                
                                -- Smaller Icon Inside
                                local innerIcon = Instance.new("ImageLabel", btn)
                                innerIcon.Size = UDim2.new(0.6, 0, 0.6, 0)
                                innerIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
                                innerIcon.AnchorPoint = Vector2.new(0.5, 0.5)
                                innerIcon.BackgroundTransparency = 1
                                innerIcon.Image = reg.icon -- Same icon as in list
                                innerIcon.ImageColor3 = WHITE
                                
                                local stroke = Instance.new("UIStroke", btn)
                                stroke.Color = SELECTED_COLOR
                                stroke.Thickness = 3
                                stroke.Enabled = reg.isOn -- Sync with current module state
                                RegisterRGB(stroke, "Stroke", SELECTED_COLOR)
                                
                                makeDraggableButton(btn, function()
                                    -- Click behavior
                                    if reg.isAction then
                                        reg.toggleFunc()
                                        TweenService:Create(innerIcon, TweenInfo.new(0.1), {ImageColor3 = SELECTED_COLOR}):Play()
                                        task.wait(0.1)
                                        TweenService:Create(innerIcon, TweenInfo.new(0.1), {ImageColor3 = WHITE}):Play()
                                    else
                                        local newState = not reg.isOn
                                        reg.toggleFunc(newState)
                                    end
                                end)
                                
                                -- Store reference to update stroke later
                                _G.ActiveMobileButtons[item.path] = {btn = btn, stroke = stroke}
                                
                                -- Initial Update
                                stroke.Enabled = reg.isOn
                                
                            else
                                -- DESTROY CIRCLE BUTTON
                                local active = _G.ActiveMobileButtons[item.path]
                                if active then
                                    if active.stroke then UnregisterRGB(active.stroke, "Stroke") end
                                    if active.btn then active.btn:Destroy() end
                                end
                                _G.ActiveMobileButtons[item.path] = nil
                            end
                        end)
                        
                        chkFrame.Parent = row
                        chkFrame.Position = UDim2.new(1, -10, 0.5, 0) -- Right Aligned
                        chkFrame.AnchorPoint = Vector2.new(1, 0.5)
                        chkFrame.Size = UDim2.new(0, 40, 0, 40) 

                    -- PC Control (Keybind Button)
                    else 
                        local keyBtn = Instance.new("TextButton", row)
                        keyBtn.Size = UDim2.new(0, 100, 0, 35)
                        keyBtn.Position = UDim2.new(1, -10, 0.5, 0) -- Right Aligned
                        keyBtn.AnchorPoint = Vector2.new(1, 0.5)
                        keyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                        keyBtn.Text = "NONE"
                        keyBtn.TextColor3 = WHITE
                        keyBtn.Font = mainFont
                        keyBtn.TextSize = 14
                        Instance.new("UICorner", keyBtn)
                        
                        local binding = false
                        keyBtn.MouseButton1Click:Connect(function()
                            binding = true
                            keyBtn.Text = "..."
                            keyBtn.TextColor3 = SELECTED_TEXT_COLOR
                        end)
                        
                        UserInputService.InputBegan:Connect(function(input)
                            if not binding then return end
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                binding = false
                                
                                -- Clear old bind for this path
                                for k, v in pairs(_G.Keybinds) do
                                    if v == item.path then _G.Keybinds[k] = nil end
                                end
                                
                                -- Set new bind
                                _G.Keybinds[input.KeyCode] = item.path
                                keyBtn.Text = input.KeyCode.Name
                                keyBtn.TextColor3 = WHITE
                            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                                -- Cancel if clicked elsewhere (simple check)
                                binding = false
                                keyBtn.Text = "NONE"
                                keyBtn.TextColor3 = WHITE
                            end
                        end)
                    end
                    
                    -- Global update function to sync visuals
                    reg.updateShortcut = function(isOn)
                        -- Sync Mobile Circle Stroke
                        local active = _G.ActiveMobileButtons[item.path]
                        if active and active.stroke then
                            active.stroke.Enabled = isOn
                        end
                    end
                end
            end
        end
    end
end

