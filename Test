    RegisterRGB(ind, "Background", WHITE) 

    local title = Instance.new("TextLabel", head)
    title.Text = name
    title.Size = UDim2.new(1, -95, 1, 0)
    title.Position = UDim2.new(0, 15, 0, 0)
    title.BackgroundTransparency = 1
    title.TextColor3 = WHITE
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Font = mainFont
    title.TextSize = 18
    
    -- Main Module Toggle Logic
    local setToggleState = function(state) end -- Placeholder, overridden below
    if toggle then
        local tr = Instance.new("TextButton", head)
        tr.Name = "ToggleTrack"
        tr.Size = UDim2.new(0, 50, 0, 24)
        tr.Position = UDim2.new(1, -12, 0.5, 0)
        tr.AnchorPoint = Vector2.new(1, 0.5)
        tr.Text = ""
        tr.AutoButtonColor = false
        Instance.new("UICorner", tr).CornerRadius = UDim.new(1,0)
        local kn = Instance.new("Frame", tr)
        kn.Size = UDim2.new(0, 18, 0, 18)
        kn.AnchorPoint = Vector2.new(0.5, 0.5)
        kn.BackgroundColor3 = WHITE
        Instance.new("UICorner", kn).CornerRadius = UDim.new(1,0)
        
        local isT = init or false
        
        setToggleState = function(newState)
            isT = newState
            local c, p
            if isT then 
                c = SELECTED_COLOR
                p = UDim2.new(1, -12, 0.5, 0)
                RegisterRGB(tr, "Background")
            else 
                c = Color3.fromRGB(120, 120, 120)
                p = UDim2.new(0, 12, 0.5, 0)
                UnregisterRGB(tr, "Background") 
            end
            TweenService:Create(tr, TweenInfo.new(getAnimSpeed()), {BackgroundColor3 = c}):Play()
            TweenService:Create(kn, TweenInfo.new(getAnimSpeed()), {Position = p}):Play()
            if toggleCallback then toggleCallback(isT) end
        end
        
        setToggleState(isT) -- Init visual
        
        tr.MouseButton1Click:Connect(function() 
             setToggleState(not isT)
        end)
    end
    
    local sett = Instance.new("Frame", frame)
    sett.Name="SettingsContainer"
    sett.Size = UDim2.new(1, 0, 0, 0)
    sett.AutomaticSize = Enum.AutomaticSize.Y
    sett.ClipsDescendants = false
    sett.Visible = false
    sett.LayoutOrder = 2
    sett.BackgroundTransparency = 1
    local list2 = Instance.new("UIListLayout", sett)
    list2.SortOrder = Enum.SortOrder.LayoutOrder
    list2.Padding = UDim.new(0, 5)
    local sp = Instance.new("UIPadding", sett)
    sp.PaddingTop=UDim.new(0,5)
    sp.PaddingBottom=UDim.new(0,5)
    sp.PaddingLeft=UDim.new(0.05,0)
    sp.PaddingRight=UDim.new(0,0) -- keep settings toggles aligned with module header toggle

    local open = false
    local hasI = false

    local function getSettingsHeight()
        return list2.AbsoluteContentSize.Y + sp.PaddingTop.Offset + sp.PaddingBottom.Offset
    end

    local function applyModuleOpenState()
        local h = open and getSettingsHeight() or 0

        sett.Visible = open
        sett.Size = UDim2.new(1, 0, 0, h)

        if open then
            -- ind is parented to head; extend downward past head into the settings panel
            ind.Position = UDim2.new(0, 4, 0, 4)
            ind.Size = UDim2.new(0, 2, 0, math.max(0, head.Size.Y.Offset + h - 8))
            ind.BackgroundTransparency = 0
        else
            -- Collapsed: span just the header height minus padding, hidden
            ind.Position = UDim2.new(0, 4, 0, 4)
            ind.Size = UDim2.new(0, 2, 0, head.Size.Y.Offset - 8)
            ind.BackgroundTransparency = 1
        end

        task.defer(function()
            updateScroll(ModuleScroll, ModuleListLayout, ModulePadding)
        end)
    end

    list2:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if open then
            applyModuleOpenState()
        end
    end)

    head.MouseButton1Click:Connect(function()
        if not hasI then return end
        open = not open
        applyModuleOpenState()
        task.defer(applyModuleOpenState)
    end)

    local api = {}
    local function mark() if not hasI then hasI = true end end
    function api:Slider(n, min, max, i, s) mark(); createSlider(n, min, max, i, s).Parent = sett; return api end
    
    function api:Select(n, o) 
        mark() 
        local f, updateFunc = createSelect(n, o, false, sett, function() return open end, ind)
        f.Parent = sett
        return api, updateFunc 
    end
    
    function api:MultiSelect(n, o) 
        mark() 
        local f, updateFunc = createSelect(n, o, true, sett, function() return open end, ind)
        f.Parent = sett
        return api, updateFunc
    end
    
    -- Sliding Toggle (default)
    function api:Toggle(n, def, c) 
        mark() 
        createSlidingToggle(n, def, c).Parent = sett 
        return api 
    end

    -- Checkbox Option
    function api:Checkbox(n, def, c) 
        mark() 
        createCheckbox(n, def, c).Parent = sett 
        return api 
    end

    function api:TextButton(n, c) mark(); createTextButton(n, c).Parent = sett; return api end
    function api:OneTimeButton(n, c) mark(); createOneTimeButton(n, c).Parent = sett; return api end
    
    -- Return frame, api, and the toggle function for external use
    return frame, api, setToggleState
end

