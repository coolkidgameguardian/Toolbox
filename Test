local function createSlider(name, minVal, maxVal, initialVal, step, callback)
    step = step or 1 
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
    applyCorner(frame)
    
    local current = initialVal or minVal
    local title = Instance.new("TextLabel", frame)
    title.Text = name
    title.Size = UDim2.new(1, -95, 0.3, 0)
    title.Position = UDim2.new(0.05, 0, 0.1, 0)
    title.BackgroundTransparency = 1
    title.TextColor3 = WHITE
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextSize = 16
    title.Font = mainFont
    
    local valLab = Instance.new("TextLabel", frame)
    valLab.Text = tostring(current)
    valLab.Size = UDim2.new(0, 50, 0.3, 0)
    valLab.Position = UDim2.new(1, -8, 0.1, 0)
    valLab.AnchorPoint = Vector2.new(1, 0)
    valLab.BackgroundTransparency = 1
    valLab.TextColor3 = WHITE
    valLab.TextXAlignment = Enum.TextXAlignment.Right
    valLab.TextSize = 16
    valLab.Font = mainFont
    
    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(1, -40, 0, 4)
    track.Position = UDim2.new(0.5, 0, 0.65, 0)
    track.AnchorPoint = Vector2.new(0.5, 0.5)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(0,0,1,0)
    fill.Position = UDim2.new(0, 0, 0.5, 0)
    fill.AnchorPoint = Vector2.new(0, 0.5)
    fill.BackgroundColor3 = SELECTED_COLOR
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
    RegisterRGB(fill, "Background") 

    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.BackgroundColor3 = WHITE
    knob.ZIndex = 5
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Text = ""
    
    local hitbox = Instance.new("TextButton", frame)
    hitbox.Size = UDim2.new(1, -40, 0, 40) 
    hitbox.Position = UDim2.new(0.5, 0, 0.65, 0)
    hitbox.AnchorPoint = Vector2.new(0.5, 0.5)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.ZIndex = 10 
    
    local function update(input)
        local sizeX = track.AbsoluteSize.X
        if sizeX == 0 then return end
        local pos = input.Position.X - track.AbsolutePosition.X
        local pct = math.clamp(pos / sizeX, 0, 1)
        local raw = minVal + (maxVal - minVal) * pct
        current = math.floor(raw / step + 0.5) * step
        local finalPct = (current - minVal) / (maxVal - minVal)
        
        fill.Size = UDim2.new(finalPct, 0, 1, 0)
        knob.Position = UDim2.new(finalPct, 0, 0.5, 0)
        valLab.Text = tostring(current)
        if callback then callback(current) end
    end
    
    local iP = (current - minVal) / (maxVal - minVal)
    fill.Size = UDim2.new(iP, 0, 1, 0)
    knob.Position = UDim2.new(iP, 0, 0.5, 0)

    hitbox.InputBegan:Connect(function(i) 
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
             if ActiveSlider == nil then
                ActiveSlider = { Update = update }
                update(i)
            end
        end 
    end)
    
    return frame
end

