updateScroll = function(frame, layout, padding)
    local h = layout.AbsoluteContentSize.Y + padding.PaddingTop.Offset + padding.PaddingBottom.Offset
    frame.CanvasSize = UDim2.new(0, 0, 0, h)
    local max = h - frame.AbsoluteWindowSize.Y
    if max < 0 then max = 0 end
    frame.CanvasPosition = Vector2.new(0, math.clamp(frame.CanvasPosition.Y, 0, max))
end

CategoryScroll:GetPropertyChangedSignal("AbsoluteWindowSize"):Connect(updateSpacer)
CategoryListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    updateScroll(CategoryScroll, CategoryListLayout, CategoryPadding)
    updateSpacer() 
end)
