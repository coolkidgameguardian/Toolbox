local Toolbox = { Categories = {}, ActiveCategory = nil }

function Toolbox:Category(name)
    local data = { Name = name, Elements = {}, Button = nil }
    local btn = Instance.new("TextButton", CategoryScroll)
    btn.Size=UDim2.new(1,0,0,45)
    btn.BackgroundColor3=DESELECTED_COLOR
    btn.BackgroundTransparency=1
    btn.Text=""
    btn.AutoButtonColor = false 
    applyStyleStroke(btn)
    local list = Instance.new("UIListLayout", btn)
    list.FillDirection=Enum.FillDirection.Horizontal
    list.VerticalAlignment=Enum.VerticalAlignment.Center
    list.Padding=UDim.new(0,5)
    Instance.new("UIPadding", btn).PaddingLeft=UDim.new(0,10)
    local icon = Instance.new("ImageLabel", btn)
    icon.Image="rbxassetid://100034294666803"
    icon.Size=UDim2.new(0,30,0,30)
    icon.BackgroundTransparency=1
    icon.ImageColor3=WHITE
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text=name
    lbl.Size=UDim2.new(0,100,1,0)
    lbl.BackgroundTransparency=1
    lbl.TextColor3=WHITE
    lbl.Font=mainFont
    lbl.TextSize=18
    lbl.TextXAlignment=Enum.TextXAlignment.Left

    btn.MouseButton1Click:Connect(function()
        if Toolbox.ActiveCategory == data then return end
        
        -- Deselect current category
        if Toolbox.ActiveCategory then
            Toolbox.ActiveCategory.Button.BackgroundColor3 = DESELECTED_COLOR
            Toolbox.ActiveCategory.Button.BackgroundTransparency = 1
            UnregisterRGB(Toolbox.ActiveCategory.Button, "Background")
            for _, e in ipairs(Toolbox.ActiveCategory.Elements) do e.Visible = false end
        end
        
        -- Hide Special Containers
        SettingsContainer.Visible = false
        ShortcutsContainer.Visible = false
        
        -- Reset Special Buttons
        SettingsButton.BackgroundTransparency = 1
        UnregisterRGB(SettingsButton, "Background")
        
        ShortcutsButton.BackgroundColor3 = DESELECTED_COLOR
        ShortcutsButton.BackgroundTransparency = 1
        UnregisterRGB(ShortcutsButton, "Background")

        -- Activate New Category
        Toolbox.ActiveCategory = data
        btn.BackgroundColor3 = SELECTED_COLOR
        btn.BackgroundTransparency = 0
        RegisterRGB(btn, "Background")
        for _, e in ipairs(data.Elements) do e.Visible = true end
    end)
    data.Button = btn
    table.insert(Toolbox.Categories, data)

    local tab = {}
    
    -- Modified to return toggleStateFunc
    function tab:ModuleSettingDropdown(n, i, cb)
        local c, a, toggleFunc = createModule(n, i, true, cb)
        c.Parent = ModuleScroll
        c.Visible = false
        table.insert(data.Elements, c)
        return a, toggleFunc -- Return API and the Toggle Function
    end
    
    function tab:Divider(n)
        local c, a = createDivider(n)
        c.Parent = ModuleScroll
        c.Visible = false
        table.insert(data.Elements, c)
        return a
    end
    function tab:OneTimeButton(n, c)
        local b = createOneTimeModuleButton(n, c)
        b.Parent = ModuleScroll
        b.Visible = false
        table.insert(data.Elements, b)
        return tab
    end
    function tab:TextButton(n, c)
        local b = createTextButton(n, c)
        b.Parent = ModuleScroll
        b.Visible = false
        table.insert(data.Elements, b)
        return tab
    end
    return tab
end

