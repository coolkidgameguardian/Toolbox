    oPad.PaddingLeft = UDim.new(0.05, 0)
    oPad.PaddingRight = UDim.new(0.05, 0)
    oPad.PaddingTop = UDim.new(0, PADDING)
    oPad.PaddingBottom = UDim.new(0, PADDING)

    local isOpen = false
    local selectedMap = {}
	if options[1] then selectedMap[options[1]] = true end 
    local buttons = {}

    local function updateParent()
        task.wait()
        if getIsOpen() then
             local l = settingsContainer:FindFirstChildOfClass("UIListLayout")
             local p = settingsContainer:FindFirstChildOfClass("UIPadding")
             if l and p then
                local h = l.AbsoluteContentSize.Y + p.PaddingTop.Offset + p.PaddingBottom.Offset
                TweenService:Create(settingsContainer, TweenInfo.new(getAnimSpeed()), {Size = UDim2.new(1, 0, 0, h)}):Play()
                local head = settingsContainer.Parent:FindFirstChild("HeaderBar")
                if head then
                    TweenService:Create(settingsIndicator, TweenInfo.new(getAnimSpeed()), {
                        Position = UDim2.new(0, 4, 0, 4),
                        Size = UDim2.new(0, 2, 0, math.max(0, head.Size.Y.Offset + h - 8))
                    }):Play()
                end
             end
        end
    end

    local function refreshOptions(newOptions)
        -- Clear old buttons
        for _, c in ipairs(optFrame:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        buttons = {}
        options = newOptions or {}
        
        for i, opt in ipairs(options) do
            local btn = Instance.new("TextButton", optFrame)
            btn.Size = UDim2.new(1, 0, 0, 35)
            btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            btn.BackgroundTransparency = 0
            btn.Text = "  " .. opt
            btn.TextColor3 = WHITE
            btn.Font = mainFont
            btn.TextSize = 16
            btn.TextXAlignment = Enum.TextXAlignment.Left
            applyCorner(btn)
            buttons[opt] = btn
            
            if selectedMap[opt] then
                 btn.TextColor3 = SELECTED_TEXT_COLOR
                RegisterRGB(btn, "Text", SELECTED_TEXT_COLOR)
            end

            btn.MouseButton1Click:Connect(function()
                if isMultiSelect then
                    selectedMap[opt] = not selectedMap[opt]
                    if selectedMap[opt] then
                         btn.TextColor3 = SELECTED_TEXT_COLOR
                        RegisterRGB(btn, "Text", SELECTED_TEXT_COLOR)
                    else
                        btn.TextColor3 = WHITE
                        UnregisterRGB(btn, "Text")
                     end
                    local c = {}
                    for _, o in ipairs(options) do if selectedMap[o] then table.insert(c, o) end end
                    selLab.Text = #c > 0 and table.concat(c, ", ") or "None"
                else
                     for n, b in pairs(buttons) do
                        b.TextColor3 = WHITE
                        selectedMap[n] = false
                        UnregisterRGB(b, "Text")
                    end
                    selectedMap[opt] = true
                    btn.TextColor3 = SELECTED_TEXT_COLOR
                    RegisterRGB(btn, "Text", SELECTED_TEXT_COLOR)
                    selLab.Text = opt
                    isOpen = false
                    optFrame.Size = UDim2.new(1, 0, 0, 0)
                    updateParent()
                end
            end)
        end
    end
    
    -- Initial build
    refreshOptions(options)

    bar.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        local h = 0
        if isOpen and #options > 0 then h = (#options * OPTION_HEIGHT) + (#options * (PADDING - 1)) + oPad.PaddingTop.Offset + oPad.PaddingBottom.Offset end
        optFrame.Size = UDim2.new(1, 0, 0, h)
        updateParent()
    end)
    
    return frame, refreshOptions
end

