    for _, c in ipairs(ShortcutsScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then
            if c ~= ShortcutsTitle then c:Destroy() end
        end
    end

    for _, catData in ipairs(AllCategories) do
        local hasItems = false
        for _, item in ipairs(catData.items) do
            if item.has_shortcut then hasItems = true break end
        end

        if hasItems then
