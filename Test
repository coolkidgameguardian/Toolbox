-- UPDATED FUNCTION TO FIX GAP ISSUE
local function updateSpacer()
    local containerH = CategoryScroll.AbsoluteWindowSize.Y
    if containerH == 0 then return end
    
    local usedHeight = 0
    local childCount = 0
    
    -- Calculate height of all visible categories
    for _, child in ipairs(CategoryScroll:GetChildren()) do
        if child:IsA("GuiObject") and child.Visible and child ~= ShortcutSpacer and child ~= ShortcutsButton then
            usedHeight = usedHeight + child.Size.Y.Offset
            childCount = childCount + 1
        end
    end
    
    -- Add padding for the categories we found (5 pixels each)
    usedHeight = usedHeight + (math.max(0, childCount) * 5)
    
    -- Height of the Shortcut button
    local footerH = 45
    
    -- Calculate how much empty space is actually left
    local available = containerH - usedHeight - footerH
    
    -- FIX: If plenty of space, show Spacer but remove 5px (to account for UIListLayout padding).
    -- If no space (or negative), HIDE spacer completely so UIListLayout just puts a single 5px gap.
    if available > 5 then
        ShortcutSpacer.Visible = true
        ShortcutSpacer.Size = UDim2.new(1, 0, 0, available - 5)
    else
        ShortcutSpacer.Visible = false
        ShortcutSpacer.Size = UDim2.new(1, 0, 0, 0)
    end
end

