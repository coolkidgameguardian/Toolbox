local function fitRootToScreen()
    local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
    local safeW = math.max(1, viewport.X - (EDGE_MARGIN * 2))
    local safeH = math.max(1, viewport.Y - (EDGE_MARGIN * 2))
