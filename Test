        local path = _G.Keybinds[input.KeyCode]
        if path then
            local reg = _G.ModuleRegistry[path]
            if reg then
                if reg.isAction then
                    reg.toggleFunc()
                else
                    reg.toggleFunc(not reg.isOn)
                end
            end
        end
    end
end)

