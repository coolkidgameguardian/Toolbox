-- RGB System
_G.RGBObjects = {
	Backgrounds = {}, 
	Texts = {},        
	Strokes = {}       
}

local function RegisterRGB(instance, type, defaultColor)
	local def = defaultColor or SELECTED_COLOR
	if type == "Background" then _G.RGBObjects.Backgrounds[instance] = def
	elseif type == "Text" then _G.RGBObjects.Texts[instance] = def
	elseif type == "Stroke" then _G.RGBObjects.Strokes[instance] = def
	end
end

local function UnregisterRGB(instance, type)
	if type == "Background" then _G.RGBObjects.Backgrounds[instance] = nil
	elseif type == "Text" then _G.RGBObjects.Texts[instance] = nil
	elseif type == "Stroke" then _G.RGBObjects.Strokes[instance] = nil
	end
end

